<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MT199 - Bank Confirmation Message</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        /* Mesaj Container - Kompüter üçün normal ölçü */
        .message-container {
            max-width: 1200px;
            width: 100%;
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        /* PDF Çap Bölməsi */
        .pdf-toolbar {
            background: #1e293b;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 15px;
            border-bottom: 3px solid #ffcc00;
        }

        .pdf-title {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .pdf-title h2 {
            color: white;
            font-size: 18px;
            font-weight: 500;
        }

        .pdf-badge {
            background: #ffcc00;
            color: #1e293b;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 600;
        }

        .pdf-buttons {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .pdf-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            padding: 10px 20px;
            border-radius: 40px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }

        .pdf-btn:hover {
            background: #ffcc00;
            color: #1e293b;
            border-color: #ffcc00;
        }

        .pdf-btn.print {
            background: #ffcc00;
            color: #1e293b;
            border: none;
        }

        .pdf-btn.print:hover {
            background: #e6b800;
        }

        /* Message Status */
        .message-status {
            background: #f8fafc;
            padding: 18px 24px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .status-indicator {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #10b981;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        .status-text {
            font-size: 14px;
            font-weight: 600;
            color: #10b981;
        }

        .message-ref {
            font-family: monospace;
            color: #475569;
            font-size: 14px;
            background: #e9eef2;
            padding: 5px 15px;
            border-radius: 20px;
        }

        .message-date {
            color: #64748b;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 5px;
            margin-left: auto;
        }

        /* Swift Banner */
        .swift-banner {
            background: linear-gradient(135deg, #003366 0%, #1a4b7a 100%);
            color: white;
            padding: 18px 24px;
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .swift-logo {
            background: rgba(255,255,255,0.15);
            padding: 8px 18px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 16px;
            letter-spacing: 1px;
        }

        .swift-title {
            font-size: 18px;
            font-weight: 500;
        }

        .swift-badge {
            background: #ffcc00;
            color: #003366;
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 600;
            margin-left: auto;
        }

        /* Mesaj Header */
        .message-header {
            padding: 24px;
            border-bottom: 1px solid #e2e8f0;
            background: #ffffff;
        }

        .header-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .bank-info {
            background: #f8fafc;
            padding: 20px;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
        }

        .bank-info-title {
            font-size: 14px;
            text-transform: uppercase;
            color: #64748b;
            letter-spacing: 0.5px;
            margin-bottom: 15px;
        }

        .bank-info-content {
            font-size: 15px;
        }

        .bank-info-content p {
            margin-bottom: 12px;
            display: flex;
            align-items: baseline;
            flex-wrap: wrap;
        }

        .bank-label {
            width: 120px;
            color: #475569;
            font-size: 14px;
        }

        .bank-value {
            color: #0a2540;
            font-weight: 500;
            font-size: 15px;
            flex: 1;
        }

        .swift-code {
            font-family: monospace;
            background: #e9eef2;
            padding: 3px 10px;
            border-radius: 6px;
            font-size: 14px;
            display: inline-block;
        }

        /* Transaction Info */
        .transaction-info {
            background: #f0f9ff;
            border: 1px solid #bae6fd;
            border-radius: 16px;
            padding: 20px 24px;
            margin: 0 24px 24px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
        }

        .transaction-code {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .code-label {
            color: #0369a1;
            font-size: 14px;
            font-weight: 600;
        }

        .code-value {
            font-family: monospace;
            font-size: 16px;
            font-weight: 600;
            color: #0c4a6e;
            background: white;
            padding: 8px 16px;
            border-radius: 30px;
            border: 1px solid #bae6fd;
        }

        .amount-display {
            background: white;
            padding: 10px 24px;
            border-radius: 40px;
            border: 1px solid #bae6fd;
        }

        .amount-value {
            font-size: 24px;
            font-weight: 700;
            color: #0a2540;
        }

        .amount-currency {
            color: #64748b;
            font-size: 16px;
            margin-left: 5px;
        }

        /* Mesaj Text */
        .message-text-container {
            padding: 0 24px 24px 24px;
        }

        .message-text {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 24px;
            font-family: 'Courier New', monospace;
            line-height: 1.8;
            font-size: 15px;
            color: #1e293b;
            margin-bottom: 24px;
        }

        .message-text p {
            margin-bottom: 20px;
        }

        .highlight {
            background: #fef9c3;
            padding: 3px 6px;
            font-weight: 600;
            color: #854d0e;
            border-radius: 4px;
        }

        /* Narrative Section - Səliqəli */
        .narrative-section {
            background: #f9fafb;
            border-left: 4px solid #2563eb;
            border-radius: 12px;
            padding: 18px 24px;
            margin: 20px 0 25px 0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }
        
        .narrative-title {
            font-size: 16px;
            font-weight: 700;
            color: #1e40af;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .narrative-title span {
            background: #dbeafe;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 12px;
            color: #1e3a8a;
        }
        
        .narrative-content {
            font-family: 'Courier New', monospace;
            font-size: 15px;
            color: #1e293b;
            line-height: 1.7;
        }
        
        .narrative-content p {
            margin-bottom: 12px;
        }

        /* Signature Box - YENİ: Yan-yana düzülmüş officer və altında PIN */
        .signature-box {
            background: #f8fafc;
            border: 1px dashed #94a3b8;
            border-radius: 16px;
            padding: 24px;
            margin-top: 20px;
        }

        .officers-row {
            display: flex;
            flex-wrap: wrap;
            gap: 40px 60px;
            margin-bottom: 25px;
        }

        .officer-card {
            flex: 1 1 250px;
        }

        .officer-name {
            font-size: 16px;
            font-weight: 600;
            color: #0a2540;
            margin-bottom: 12px;
            padding-bottom: 6px;
            border-bottom: 2px solid #cbd5e1;
            display: inline-block;
        }

        .pins-row {
            display: flex;
            flex-wrap: wrap;
            gap: 40px 60px;
            border-top: 1px solid #d1d5db;
            padding-top: 20px;
        }

        .pin-card {
            flex: 1 1 250px;
            display: flex;
            align-items: baseline;
            gap: 10px;
        }

        .pin-label {
            font-size: 14px;
            font-weight: 600;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .pin-value {
            font-family: 'Courier New', monospace;
            font-size: 16px;
            font-weight: 600;
            color: #075985;
            background: #e6f0f9;
            padding: 4px 14px;
            border-radius: 30px;
        }
        
        .date-field {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
            background: #ffffff;
            padding: 12px 18px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
        }
        
        .date-label {
            font-weight: 600;
            color: #334155;
            font-size: 14px;
        }
        
        .date-value {
            font-weight: 600;
            color: #0a2540;
        }

        /* Təhlükəsizlik Bölməsi */
        .security-footer {
            background: linear-gradient(135deg, #0f2b3d 0%, #1a3a4e 100%);
            padding: 24px;
            border-top: 3px solid #ffcc00;
        }

        .payment-cards {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 30px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .card-icon.visa {
            color: white;
            font-size: 28px;
            font-weight: 800;
            font-style: italic;
            background: #1a1f71;
            padding: 6px 18px;
            border-radius: 8px;
        }

        .card-icon.mastercard {
            display: flex;
            align-items: center;
            gap: 3px;
        }

        .mastercard-circle {
            width: 35px;
            height: 35px;
            border-radius: 50%;
        }

        .circle-left {
            background: #eb001b;
            opacity: 0.9;
        }

        .circle-right {
            background: #f79e1b;
            margin-left: -15px;
            opacity: 0.9;
        }

        .card-icon.amex {
            color: white;
            font-size: 26px;
            font-weight: 600;
            background: #006fcf;
            padding: 6px 18px;
            border-radius: 8px;
        }

        .secure-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            color: #94a3b8;
            font-size: 14px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .secure-badge span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .verification-bar {
            background: rgba(255,255,255,0.1);
            border-radius: 50px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 15px;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .verify-label {
            color: white;
            font-size: 15px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .verify-shield {
            color: #ffcc00;
            font-size: 18px;
        }

        .verify-code {
            background: rgba(255,255,255,0.2);
            padding: 8px 20px;
            border-radius: 40px;
            color: #ffcc00;
            font-family: monospace;
            font-size: 16px;
            font-weight: 600;
            letter-spacing: 2px;
        }

        .verify-status {
            color: #10b981;
            font-size: 15px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .security-note {
            text-align: center;
            color: #94a3b8;
            font-size: 13px;
            margin-top: 18px;
            line-height: 1.6;
        }

        /* Çap üçün stil */
        @media print {
            body {
                background: white;
                padding: 0;
            }
            
            .pdf-toolbar {
                display: none;
            }
            
            .message-container {
                box-shadow: none;
                border: 1px solid #ddd;
                max-width: 100%;
            }
            
            .status-dot {
                animation: none;
            }
        }

        /* Responsive */
        @media (max-width: 900px) {
            .header-grid {
                grid-template-columns: 1fr;
            }
            
            .transaction-info {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .officers-row, .pins-row {
                flex-direction: column;
                gap: 20px;
            }
        }

        @media (max-width: 600px) {
            body {
                padding: 15px;
            }
            
            .message-status {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .message-date {
                margin-left: 0;
            }
            
            .swift-banner {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .swift-badge {
                margin-left: 0;
            }
            
            .bank-info-content p {
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }
            
            .bank-label {
                width: 100%;
            }
            
            .verification-bar {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .pdf-toolbar {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .pdf-buttons {
                width: 100%;
                justify-content: space-between;
            }
        }
    </style>
</head>
